<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | SecureView Charth</title>
    <link rel="icon" href="https://charth.vteximg.com.br/arquivos/favicon.ico">
    <link rel="stylesheet" href="/public/shared/css/base.css">
    <style>
        body {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            background: var(--charth-offwhite);
        }
        .access-card {
            background: var(--charth-offwhite);
            border: 1px solid var(--charth-border);
            border-radius: var(--radius-md);
            padding: 52px 44px;
            width: 100%;
            max-width: 420px;
            box-shadow: var(--shadow-card);
            text-align: center;
        }
        .access-logo {
            height: 30px;
            width: auto;
            margin: 0 auto 28px;
            display: block;
        }
        .access-divider {
            width: 28px;
            height: 1px;
            background: var(--charth-rose);
            margin: 0 auto 28px;
        }
        .doc-title {
            font-size: 0.9rem;
            color: var(--charth-text-secondary);
            font-weight: 300;
            letter-spacing: 0.04em;
            margin-bottom: 32px;
            word-break: break-word;
            line-height: 1.5;
        }
        .status-message {
            background: var(--charth-cream);
            border: 1px solid var(--charth-border);
            border-radius: var(--radius-sm);
            padding: 28px 20px;
            text-align: center;
        }
        .status-icon {
            font-size: 1.8rem;
            display: block;
            margin-bottom: 12px;
        }
        .status-message strong {
            display: block;
            font-size: 0.88rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--charth-text-primary);
            margin-bottom: 8px;
        }
        .status-message p {
            font-size: 0.85rem;
            color: var(--charth-text-muted);
            font-weight: 300;
            line-height: 1.6;
        }
        .error-msg {
            background: #F0DADA;
            border: 1px solid rgba(148,48,48,0.2);
            color: #6B2020;
            padding: 10px 14px;
            border-radius: var(--radius-sm);
            font-size: 0.85rem;
            margin-bottom: 20px;
        }
        .form-group {
            margin-bottom: 20px;
            text-align: left;
        }
        .access-card .form-group label {
            display: block;
            font-size: 0.72rem;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: var(--ls-label);
            color: var(--charth-text-muted);
            margin-bottom: 6px;
        }
        .btn-access {
            width: 100%;
            padding: 13px;
            background: var(--charth-black);
            color: #fff;
            border: none;
            border-radius: var(--radius-sm);
            font-family: var(--font-main);
            font-size: 0.78rem;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: var(--ls-button);
            cursor: pointer;
            transition: var(--transition);
        }
        .btn-access:hover {
            background: var(--charth-text-primary);
        }
        .continue-link {
            display: inline-block;
            margin-top: 20px;
            font-size: 0.78rem;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: var(--ls-label);
            color: var(--charth-text-muted);
            text-decoration: none;
            transition: var(--transition);
        }
        .continue-link:hover {
            color: var(--charth-text-primary);
        }
        .divider {
            border: none;
            border-top: 1px solid var(--charth-border);
            margin: 24px 0;
        }
        .already-auth {
            background: #D5E4D3;
            border: 1px solid rgba(63,107,61,0.2);
            border-radius: var(--radius-sm);
            padding: 16px;
            margin-bottom: 20px;
        }
        .already-auth p {
            font-size: 0.85rem;
            color: #3F4F3E;
            font-weight: 300;
        }
        .footer-credit {
            margin-top: 32px;
            font-size: 0.7rem;
            font-weight: 300;
            color: var(--charth-text-muted);
            letter-spacing: 0.04em;
        }
    </style>
</head>
<body>
    <div class="access-card">
        <img
            src="https://charth.vtexassets.com/assets/vtex/assets-builder/charth.store/1.1.133/img/logo-charth___cdf0830626d6b6c0798360d0e9cf8d7e.png"
            alt="Charth"
            class="access-logo"
        >
        <div class="access-divider"></div>
        <p class="doc-title"><%= title %></p>

        <% if (status === 'not_found') { %>
            <div class="status-message">
                <span class="status-icon">—</span>
                <strong>Link Inválido</strong>
                <p>Este link não existe ou foi removido.</p>
            </div>

        <% } else if (status === 'disabled') { %>
            <div class="status-message">
                <span class="status-icon">—</span>
                <strong>Acesso Desativado</strong>
                <p>Este link de acesso foi desativado pelo administrador.</p>
            </div>

        <% } else if (status === 'unavailable') { %>
            <div class="status-message">
                <span class="status-icon">—</span>
                <strong>Documento Indisponível</strong>
                <p>Este documento não está disponível no momento.</p>
            </div>

        <% } else if (status === 'expired') { %>
            <div class="status-message">
                <span class="status-icon">—</span>
                <strong>Link Expirado</strong>
                <p>O prazo de acesso para este link foi encerrado.</p>
            </div>

        <% } else if (status === 'limit_reached') { %>
            <div class="status-message">
                <span class="status-icon">—</span>
                <strong>Limite Atingido</strong>
                <p>O número máximo de visualizações para este link foi atingido.</p>
            </div>

        <% } else { %>

            <% if (error) { %>
                <div class="error-msg"><%= error %></div>
            <% } %>

            <% if (alreadyAuthed) { %>
                <div class="already-auth">
                    <p>Você já está autenticado para este documento.</p>
                </div>
                <a href="/v/<%= token %>/view" class="continue-link">Continuar visualizando &rarr;</a>
                <hr class="divider">
                <p style="font-size:0.75rem;color:var(--charth-text-muted);margin-bottom:14px;text-align:left;text-transform:uppercase;letter-spacing:var(--ls-label);">Ou entre novamente</p>
            <% } %>

            <form method="POST" action="/v/<%= token %>/auth" autocomplete="off">
                <div class="form-group">
                    <label for="password">Senha de Acesso</label>
                    <input
                        type="password"
                        id="password"
                        name="password"
                        class="form-control"
                        required
                        autofocus
                        autocomplete="current-password"
                        placeholder="Digite a senha fornecida"
                    >
                </div>
                <button type="submit" class="btn-access">Acessar</button>
            </form>

        <% } %>
    </div>
    <p class="footer-credit">Powered by SecureView · Charth</p>
</body>
</html>
