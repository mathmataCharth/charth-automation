<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Logs de Acesso - SecureView Admin</title>
    <link rel="stylesheet" href="/public/shared/css/base.css">
    <link rel="stylesheet" href="/public/admin/css/admin.css">
</head>
<body>
    <header class="admin-header">
        <div class="header-inner">
            <span class="header-brand">SecureView Admin</span>
            <nav class="header-nav">
                <a href="/admin/dashboard" class="nav-link">Dashboard</a>
                <a href="/admin/logs" class="nav-link active">Logs</a>
                <form method="POST" action="/admin/logout" style="display:inline;">
                    <button type="submit" class="btn btn-outline-sm">Sair (<%= adminUsername %>)</button>
                </form>
            </nav>
        </div>
    </header>

    <main class="admin-main">
        <div class="page-title-row">
            <h2>Logs de Acesso</h2>
        </div>

        <!-- Filters -->
        <div class="card mb-24">
            <div class="card-header"><h3>Filtros</h3></div>
            <div class="card-body">
                <form method="GET" action="/admin/logs" class="filter-form">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="documentId">Documento</label>
                            <select id="documentId" name="documentId" class="form-control">
                                <option value="">Todos</option>
                                <% documents.forEach(doc => { %>
                                    <option value="<%= doc.id %>" <%= (filters.documentId == doc.id) ? 'selected' : '' %>>
                                        <%= doc.title %>
                                    </option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="action">Ação</label>
                            <select id="action" name="action" class="form-control">
                                <option value="">Todas</option>
                                <option value="password_attempt" <%= filters.action === 'password_attempt' ? 'selected' : '' %>>Tentativa de senha</option>
                                <option value="password_success" <%= filters.action === 'password_success' ? 'selected' : '' %>>Senha correta</option>
                                <option value="password_failure" <%= filters.action === 'password_failure' ? 'selected' : '' %>>Senha incorreta</option>
                                <option value="view_start" <%= filters.action === 'view_start' ? 'selected' : '' %>>Visualização</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="dateFrom">De</label>
                            <input type="date" id="dateFrom" name="dateFrom" class="form-control" value="<%= filters.dateFrom || '' %>">
                        </div>
                        <div class="form-group">
                            <label for="dateTo">Até</label>
                            <input type="date" id="dateTo" name="dateTo" class="form-control" value="<%= filters.dateTo || '' %>">
                        </div>
                        <div class="form-group align-bottom">
                            <button type="submit" class="btn btn-primary">Filtrar</button>
                            <a href="/admin/logs" class="btn btn-secondary">Limpar</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- Logs Table -->
        <div class="card">
            <div class="card-header">
                <h3>Registros (<%= logs.length %>)</h3>
            </div>
            <div class="card-body p-0">
                <% if (logs.length === 0) { %>
                    <p class="empty-state">Nenhum log encontrado com os filtros aplicados.</p>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Data/Hora</th>
                                    <th>Documento</th>
                                    <th>Destinatário</th>
                                    <th>Ação</th>
                                    <th>IP</th>
                                    <th>User Agent</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% logs.forEach(entry => { %>
                                    <tr>
                                        <td class="text-sm text-nowrap"><%= entry.created_at.slice(0, 19).replace('T', ' ') %></td>
                                        <td class="text-sm"><%= entry.document_title %></td>
                                        <td class="text-sm">
                                            <strong><%= entry.recipient_name %></strong>
                                            <% if (entry.recipient_email) { %>
                                                <br><span class="text-muted"><%= entry.recipient_email %></span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <% if (entry.action === 'password_success') { %>
                                                <span class="badge badge-success">Autenticado</span>
                                            <% } else if (entry.action === 'password_failure') { %>
                                                <span class="badge badge-danger">Senha errada</span>
                                            <% } else if (entry.action === 'password_attempt') { %>
                                                <span class="badge badge-warning">Tentativa</span>
                                            <% } else if (entry.action === 'view_start') { %>
                                                <span class="badge badge-info">Visualizando</span>
                                            <% } else { %>
                                                <span class="badge"><%= entry.action %></span>
                                            <% } %>
                                        </td>
                                        <td class="text-sm text-muted"><%= entry.ip_address || '—' %></td>
                                        <td class="text-sm text-muted ua-cell" title="<%= entry.user_agent || '' %>">
                                            <%= entry.user_agent ? entry.user_agent.slice(0, 60) + (entry.user_agent.length > 60 ? '…' : '') : '—' %>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
        </div>
    </main>

    <script src="/public/admin/js/admin.js"></script>
</body>
</html>
