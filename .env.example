# Server
PORT=3000
NODE_ENV=production
BASE_URL=http://localhost:3000

# Session
SESSION_SECRET=gerar-com-crypto-randomBytes-64-aqui

# Admin (seed inicial)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=trocar-na-primeira-vez

# Rate Limiting
MAX_PASSWORD_ATTEMPTS=5
PASSWORD_ATTEMPT_WINDOW_MINUTES=1

# Viewer Session
VIEWER_SESSION_MAX_AGE_HOURS=2

# Upload
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=./uploads
