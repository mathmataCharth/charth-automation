<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Acesso Seguro - <%= title %></title>
    <link rel="stylesheet" href="/public/shared/css/base.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            background: #1a1a1a;
            color: #ffffff;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .access-card {
            background: #252525;
            border: 1px solid #333;
            border-radius: 12px;
            padding: 48px 40px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.5);
        }
        .lock-icon {
            font-size: 2.5rem;
            text-align: center;
            margin-bottom: 20px;
        }
        .access-card h1 {
            font-size: 1.2rem;
            font-weight: 600;
            text-align: center;
            margin-bottom: 6px;
            color: #f0f0f0;
        }
        .access-card .doc-title {
            font-size: 0.95rem;
            color: #999;
            text-align: center;
            margin-bottom: 32px;
            word-break: break-word;
        }
        .status-message {
            background: #1a1a1a;
            border-radius: 8px;
            padding: 20px;
            text-align: center;
            color: #aaa;
            font-size: 0.95rem;
            line-height: 1.6;
        }
        .status-message .status-icon {
            font-size: 2rem;
            display: block;
            margin-bottom: 12px;
        }
        .status-message strong {
            display: block;
            font-size: 1.1rem;
            color: #e74c3c;
            margin-bottom: 8px;
        }
        .form-group {
            margin-bottom: 20px;
        }
        .form-group label {
            display: block;
            font-size: 0.85rem;
            color: #aaa;
            margin-bottom: 8px;
        }
        .form-control {
            width: 100%;
            background: #333;
            border: 1px solid #444;
            color: #fff;
            padding: 12px 14px;
            border-radius: 6px;
            font-size: 1rem;
            outline: none;
            transition: border-color 0.2s;
        }
        .form-control:focus {
            border-color: #4a9eff;
        }
        .btn-access {
            width: 100%;
            padding: 13px;
            background: #4a9eff;
            color: #fff;
            border: none;
            border-radius: 6px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.2s;
        }
        .btn-access:hover {
            background: #3585e0;
        }
        .error-msg {
            background: rgba(231, 76, 60, 0.15);
            border: 1px solid rgba(231, 76, 60, 0.4);
            color: #e74c3c;
            padding: 10px 14px;
            border-radius: 6px;
            font-size: 0.9rem;
            margin-bottom: 18px;
            text-align: center;
        }
        .continue-link {
            display: block;
            text-align: center;
            margin-top: 16px;
            color: #4a9eff;
            text-decoration: none;
            font-size: 0.95rem;
        }
        .continue-link:hover {
            text-decoration: underline;
        }
        .divider {
            border: none;
            border-top: 1px solid #333;
            margin: 20px 0;
        }
    </style>
</head>
<body>
    <div class="access-card">
        <div class="lock-icon">&#128274;</div>
        <h1>Documento Protegido</h1>
        <p class="doc-title"><%= title %></p>

        <% if (status === 'not_found') { %>
            <div class="status-message">
                <span class="status-icon">&#10060;</span>
                <strong>Link Inválido</strong>
                Este link não existe ou foi removido.
            </div>

        <% } else if (status === 'disabled') { %>
            <div class="status-message">
                <span class="status-icon">&#128683;</span>
                <strong>Acesso Desativado</strong>
                Este link de acesso foi desativado pelo administrador.
            </div>

        <% } else if (status === 'unavailable') { %>
            <div class="status-message">
                <span class="status-icon">&#128683;</span>
                <strong>Documento Indisponível</strong>
                Este documento não está disponível no momento.
            </div>

        <% } else if (status === 'expired') { %>
            <div class="status-message">
                <span class="status-icon">&#8987;</span>
                <strong>Link Expirado</strong>
                O prazo de acesso para este link foi encerrado.
            </div>

        <% } else if (status === 'limit_reached') { %>
            <div class="status-message">
                <span class="status-icon">&#9888;</span>
                <strong>Limite Atingido</strong>
                O número máximo de visualizações para este link foi atingido.
            </div>

        <% } else { %>

            <% if (error) { %>
                <div class="error-msg"><%= error %></div>
            <% } %>

            <% if (alreadyAuthed) { %>
                <div class="status-message" style="color:#ccc; background:#1e2d1e; border:1px solid #2a4a2a;">
                    <span class="status-icon">&#9989;</span>
                    Você já está autenticado para este documento.
                </div>
                <a href="/v/<%= token %>/view" class="continue-link">Continuar visualizando &rarr;</a>
                <hr class="divider">
                <p style="text-align:center;color:#777;font-size:0.85rem;margin-bottom:12px;">Ou entre com a senha novamente:</p>
            <% } %>

            <form method="POST" action="/v/<%= token %>/auth" autocomplete="off">
                <div class="form-group">
                    <label for="password">Senha de acesso</label>
                    <input
                        type="password"
                        id="password"
                        name="password"
                        class="form-control"
                        required
                        autofocus
                        autocomplete="current-password"
                        placeholder="Digite a senha fornecida"
                    >
                </div>
                <button type="submit" class="btn-access">Acessar Documento</button>
            </form>

        <% } %>
    </div>
</body>
</html>
